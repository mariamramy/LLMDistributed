              "raw": "{\n  \"task_id\": \"postman-worker2-{{$timestamp}}\",\n  \"prompt\": \"{{sample_prompt}}\",\n  \"use_rag\": true\n}"
            },
            "url": {
              "raw": "{{worker_2_base_url}}/task",
              "host": ["{{worker_2_base_url}}"],
              "path": ["task"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Worker 2 RAG task completes', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.worker_id).to.eql('worker-2');",
                  "  pm.expect(body.rag.used).to.eql(true);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
